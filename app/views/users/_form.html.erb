<div class="container">
  <div class="row justify-content-center">
    <div class="col-lg-10">
      <%= render 'shared/errors', obj: @user %>

      <%= form_with(model: @user, class: "shadow p-3 mb-3 bg-info rounded", local: true) do |f| %>

        <div class="row mb-3">
          <%= f.label :username, class: "col-sm-2 col-form-label text-light" %>
          <div class="col-sm-10">
            <%= f.text_field :username,
                class: "form-control shadow-sm",
                placeholder: "Enter a username" %>
          </div>
        </div>

        <div class="row mb-3">
          <%= f.label :email, class: "col-sm-2 col-form-label text-light" %>
          <div class="col-sm-10">
            <%= f.email_field :email,
                class: "form-control shadow-sm",
                placeholder: "Enter your email address" %>
          </div>
        </div>

        <div class="row mb-3">
          <%= f.label :password, class: "col-sm-2 col-form-label text-light" %>
          <div class="col-sm-10">
            <%= f.password_field :password,
                class: "form-control shadow-sm",
                placeholder: "Choose a password" %>
          </div>
        </div>

        <div class="row">
          <div class="col text-center">
            <%= f.submit(@user.new_record? ? "Sign Up" : "Update account", class: "btn btn-outline-light btn-lg")  %>
          </div>
        </div>

      <% end %>
    </div>

    <div class="mb-3 text-center">
      <%= link_to '[ Cancel and return to articles listing ]',
          articles_path,
          class: "text-info" %>
    </div>
  </div>
</div>